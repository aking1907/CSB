  <Code>Public Function BlankZero(ByVal Value As Decimal)
    if Value = 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankPos(ByVal Value As Decimal)
    if Value &gt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankZeroAndPos(ByVal Value As Decimal)
    if Value &gt;= 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNeg(ByVal Value As Decimal)
    if Value &lt; 0 then
        Return ""
    end if
    Return Value
End Function

shared oldvalue1 as String
shared oldvalue2 as String
shared oldvalue3 as Integer
shared oldvalue4 as Integer
shared counter as Integer
shared data as String

Public Function GetPageNumber(ByVal value1 As String,ByVal value2 As String,ByVal value3 As Integer,ByVal value4 As Integer)
   if value1=oldvalue1  and   value2=oldvalue2 and value3=oldvalue3   and oldvalue4=value4 then
       counter=counter+1
  else 
       counter=1
       oldvalue1=value1
       oldvalue2 =value2
       oldvalue3 =value3
       oldvalue4=value4
   end if
  return counter
End Function

Public Function SetData(ByVal NewData As Object)
  if NewData&gt;"" then
   data=NewData
end if
Return True
End Function

Public Function GetData(ByVal Num As Integer)
 return Cstr(Choose(Num,Split(Cstr(data),Chr(177))))
End Function

Shared offset as Integer
Shared newPage as Object
Shared currentgroup1 as Object
Shared currentgroup2 as Object
Shared currentgroup3 as Object
Shared currentgroup4 as Object
Public Function GetGroupPageNumber(NewPage as Boolean, pagenumber as Integer) as Object
  If NewPage
    offset = pagenumber - 1
  End If
  Return pagenumber - offset
End Function

Public Function IsNewPage(group1 as Object, group2 as Object,group3 as Object, group4 as Object) As Boolean
newPage = FALSE
If Not (group1 = currentgroup1)
    newPage = TRUE
    currentgroup1 = group1
    currentgroup2 = group2
    currentgroup3 = group3
    currentgroup4 = group4
    ELSE 
      If Not (group2 = currentgroup2)
        newPage = TRUE 
        currentgroup2 = group2
        currentgroup3 = group3
        currentgroup4 = group4
       ELSE 
         If Not (group3 = currentgroup3)
           newPage = TRUE 
           currentgroup3 = group3
           currentgroup4 = group4
        ELSE 
           If Not (group4 = currentgroup4)
              newPage = TRUE 
              currentgroup4 = group4          
      End If
      End If
      End If
  End If
  Return newPage
End Function
</Code>
